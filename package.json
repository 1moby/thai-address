{
  "name": "@1moby/thai-address",
  "version": "0.1.1",
  "description": "Compact browser-only Thai address autocomplete, parser, React component, and plain JavaScript enhancer.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1moby/thai-address.git"
  },
  "homepage": "https://1moby.github.io/thai-address/",
  "bugs": {
    "url": "https://github.com/1moby/thai-address/issues"
  },
  "keywords": [
    "thai",
    "address",
    "autocomplete",
    "react",
    "browser",
    "dopa",
    "thailand"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "import": "./dist/dom/index.js"
    },
    "./data/core": "./data/thai-address-core.json.gz"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "clean": "rm -rf dist demo-dist data public/data/thai-address-core.json.gz",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:data": "tsx src/build/buildData.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:seo": "tsx src/build/buildDemoSeo.ts",
    "build": "npm run build:data && npm run build:types && npm run build:demo && npm run build:seo",
    "dev": "vite --config vite.demo.config.ts --host 127.0.0.1",
    "preview": "vite preview --config vite.demo.config.ts --host 127.0.0.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "lucide-react": "^1.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "xlsx": "^0.18.5"
  }
}
