    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/build"
  ]
}
